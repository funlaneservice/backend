PORT=4000
NODE_ENV=development

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/funlane?schema=public"

JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:3000

# Until a sending domain is verified in Resend, EMAIL_FROM must use their shared
# onboarding@resend.dev address — swap in a verified @funlane.com address once one exists.
RESEND_API_KEY=
EMAIL_FROM="Funlane Travel <onboarding@resend.dev>"

# TEMPORARY: while no sending domain is verified, Resend can only deliver to the
# account's own address. Set this to that address to redirect all outgoing emails there
# (subject/body are annotated with the real intended recipient). Remove once a domain is verified.
EMAIL_REDIRECT_TO=

# Optional until file uploads are wired up. S3 bucket must be private — files are only
# ever accessed via presigned GET URLs. Until these are set, uploads fail with a 503.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Fallback file storage, used when S3 isn't configured or an S3 upload call fails.
# Files are stored with type "authenticated" and only ever served via signed URLs.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Wallet topups (initialize + webhook verification). Agency payout via Paystack Transfer
# is a separate, not-yet-built feature gated on a PAYSTACK_AGENCY_RECIPIENT_CODE.
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# Server-side Google OAuth (Credentials > OAuth 2.0 Client IDs > Web application in Google
# Cloud Console). This is a redirect flow entirely owned by the backend — the frontend needs
# no Google-specific code, just a link to GET /api/auth/google. GOOGLE_CALLBACK_URL must be
# registered in the console under "Authorized redirect URIs" and must exactly match this
# backend's public URL + /api/auth/google/callback. Until all three are set, GET /auth/google
# redirects to the frontend's callback route with an error instead of reaching Google.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback
